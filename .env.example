# ╔══════════════════════════════════════════════════════════╗
# ║         CloseCLAW — Configuration Template              ║
# ║  Copy this file to .env and fill in your real values    ║
# ╚══════════════════════════════════════════════════════════╝

# ── TELEGRAM ──────────────────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Your Telegram User ID (get from @userinfobot)
# Multiple IDs separated by comma: 123456789,987654321
ALLOWED_USER_IDS=

# ── io.net CLOUD AI ───────────────────────────────────────────
# Get from https://cloud.io.net → API Keys section
IO_NET_API_KEY=

# io.net API endpoint (do not change)
IONET_BASE_URL=https://api.intelligence.io.solutions/api/v1

# Model to use (change if needed)
IONET_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── OLLAMA LOCAL AI ───────────────────────────────────────────
# Local Ollama instance (install from https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434

# Local model to pull and run: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# ── SECURITY ──────────────────────────────────────────────────
# Password used to encrypt the bot token store (AES-256)
# Use a strong random password — losing this = losing stored tokens
TOKEN_STORE_PASSWORD=

# ── DASHBOARD ─────────────────────────────────────────────────
DASHBOARD_PORT=3000
